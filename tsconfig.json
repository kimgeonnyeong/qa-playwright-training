{
    "compilerOptions": {
      "target": "ES2020",
      "module": "commonjs",
      "lib": ["ES2020", "DOM"],
      "types": ["node", "@playwright/test"],
      "moduleResolution": "node",
      "resolveJsonModule": true,
      "esModuleInterop": true,
      "strict": false,
      "skipLibCheck": true
    },
    "include": ["tests", "pages", "utils"]
  }